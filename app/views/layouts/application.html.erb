<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= content_for?(:title) ? "#{yield(:title)} — " : "" %>Project Glutenberg</title>
  <link rel="stylesheet" href="https://unpkg.com/@sakun/system.css">
  <style>
    /* Override system.css: single page scroll, no scrollbars on panes unless needed */
    html { overflow-x: hidden; }
    body {
      background: #ddd url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" width="4" height="4"><rect width="1" height="1" fill="%23ccc"/></svg>') repeat;
      padding: 0;
      margin: 0;
    }

    /* Menu bar sits at top of screen like real System 6 */
    ul[role="menu-bar"] { margin-bottom: 0; }

    .desktop {
      padding: 1.5rem;
      max-width: 960px;
      margin: 0 auto;
    }

    /* Window grows with content; only the document scrolls */
    .window {
      width: 100%;
      overflow: visible;
      display: block;
    }
    /* Panes flow naturally; scrollbar only when content overflows (override system.css height:100%; overflow-y:scroll) */
    .window-pane {
      padding: 0.75rem;
      height: auto;
      min-height: 0;
      overflow-y: visible;
      overflow-x: hidden;
    }

    /* Details bar styling */
    .details-bar {
      font-size: 0.8rem;
    }
    .details-bar span { margin-right: 4px; }

    /* Table styling */
    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.85rem;
    }
    th, td {
      text-align: left;
      padding: 4px 8px;
      border-bottom: 1px solid #999;
    }
    th { font-weight: bold; border-bottom: 2px solid #000; }
    tr:hover td { background: #000; color: #fff; }
    td a { color: inherit; }
    tr:hover td a { color: #fff; }

    /* Metadata grid (used inside window-pane) */
    .meta-grid {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 2px 12px;
      font-size: 0.85rem;
    }
    .meta-grid dt { font-weight: bold; white-space: nowrap; }
    .meta-grid dd { margin: 0; }

    /* Section headers inside a single window */
    .section-header {
      font-weight: bold;
      font-size: 0.9rem;
      padding: 4px 8px;
      background: #000;
      color: #fff;
      margin: 0;
    }

    /* Recipe detail */
    .ingredient-list { list-style: none; padding: 0; margin: 0; }
    .ingredient-list li {
      padding: 3px 8px;
      border-bottom: 1px dotted #999;
      font-size: 0.85rem;
    }
    .ingredient-list li:last-child { border-bottom: none; }

    .instruction-list { padding-left: 1.5rem; margin: 0; }
    .instruction-list li {
      padding: 3px 0;
      font-size: 0.85rem;
    }

    .badge {
      display: inline-block;
      padding: 1px 6px;
      border: 1px solid #000;
      font-size: 0.75rem;
      font-weight: bold;
    }
    .badge-success { background: #fff; }
    .badge-failed { background: #000; color: #fff; }

    .substitutions {
      font-size: 0.8rem;
      color: #997a00;
      font-style: italic;
    }

    .preparation-note {
      font-size: 0.75rem;
      color: #666;
      font-style: italic;
      display: block;
    }

    .foundation-food {
      font-size: 0.75rem;
      color: #666;
      margin-left: 0.5rem;
    }

    .product-highlight {
      color:rgb(242, 66, 154);
      font-weight: bold;
    }

    .product-highlight-link {
      color: rgb(242, 66, 154);
      font-weight: bold;
      text-decoration: none;
    }
    .product-highlight-link:hover {
      text-decoration: underline;
    }

    .empty-state {
      text-align: center;
      padding: 2rem;
      color: #666;
      font-style: italic;
    }

    .time-info {
      display: inline-flex;
      gap: 0.75rem;
      font-size: 0.8rem;
    }

    pre.original-text {
      white-space: pre-wrap;
      font-size: 0.8rem;
      margin: 0;
      padding: 8px;
    }

    .original-text-input {
      width: 100%;
      box-sizing: border-box;
      white-space: pre-wrap;
      font-size: 0.8rem;
      font-family: inherit;
      margin: 0 0 8px 0;
      padding: 8px;
    }

    .muted {
      font-size: 0.8rem;
      color: #666;
      font-weight: normal;
    }

    /* Book cover image */
    .book-cover {
      border: 1px solid #000;
      display: block;
    }
    .book-cover-sm {
      width: 40px;
      height: auto;
      vertical-align: middle;
    }
    .book-cover-lg {
      max-width: 200px;
      height: auto;
      float: right;
      margin: 0 0 8px 12px;
    }

    /* Group name label */
    .group-name {
      font-weight: bold;
      font-size: 0.8rem;
      padding: 3px 8px;
      background: #eee;
      border-bottom: 1px solid #999;
    }

    .pagination-links {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.5rem;
      font-size: 0.9rem;
    }

    /* Table scroll on small screens */
    .table-wrapper {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      margin: 0 -0.75rem;
      padding: 0 0.75rem;
    }
    .table-wrapper table { min-width: 600px; }

    .filter-form {
      display: flex;
      gap: 8px;
      align-items: center;
      flex-wrap: wrap;
    }
    .filter-form input[type="text"] { flex: 1; min-width: 150px; }
    .filter-form select { max-width: 220px; }

    /* Responsive: small screens */
    @media (max-width: 768px) {
      .desktop {
        padding: 0.75rem;
      }
      .meta-grid {
        grid-template-columns: 1fr;
      }
      .book-cover-lg {
        float: none;
        display: block;
        max-width: 100%;
        margin: 0 0 12px 0;
      }
      .details-bar {
        font-size: 0.75rem;
        display: flex;
        flex-wrap: wrap;
        gap: 2px 6px;
      }
      table {
        font-size: 0.8rem;
      }
      th, td {
        padding: 4px 6px;
      }
      .section-header { font-size: 0.85rem; }
      .ingredient-list li, .instruction-list li { font-size: 0.8rem; }
      .menu-stats {
        float: none;
        display: block;
        margin-top: 2px;
      }
    }

    /* Responsive: very small screens */
    @media (max-width: 480px) {
      .desktop {
        padding: 0.5rem;
      }
      .window-pane {
        padding: 0.5rem;
      }
      .table-wrapper {
        margin: 0 -0.5rem;
        padding: 0 0.5rem;
      }
      .table-wrapper table { min-width: 500px; }
      .filter-form input[type="text"] { min-width: 0; }
      .filter-form select { max-width: 100%; }
      .title-bar .title {
        font-size: 0.9rem;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
    }
  </style>
</head>
<body>
  <%# Menu bar — always at top, like real System 6 %>
  <ul role="menu-bar">
    <li role="menu-item" tabindex="0" aria-haspopup="true">
      File
      <ul role="menu">
        <li role="menu-item"><%= link_to "Sources", sources_path %></li>
      </ul>
    </li>
    <li role="menu-item" tabindex="0" aria-haspopup="false">
      <%= link_to "Sources", sources_path %>
    </li>
    <li role="menu-item" tabindex="0" aria-haspopup="false">
      <%= link_to "Ingredients", ingredients_path %>
    </li>
    <li role="menu-item" tabindex="0" aria-haspopup="false">
      <span class="menu-stats" style="float: right; font-size: 0.8rem;">
        <% menu_counts = Rails.cache.fetch("layout_menu_counts", expires_in: 1.minute) { { sources: Source.count, recipes: Recipe.successful.count } } %>
        <%= menu_counts[:sources] %> sources · <%= menu_counts[:recipes] %> recipes
      </span>
    </li>
  </ul>

  <div class="desktop">
    <%= yield %>
  </div>
</body>
</html>
